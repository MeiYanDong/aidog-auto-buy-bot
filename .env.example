OKX_API_KEY= # OKX API Key（必填）
OKX_SECRET_KEY= # OKX API Secret（必填）
OKX_PASSPHRASE= # OKX API Passphrase（必填）
BOT_NAME=AIDOG Bot # 飞书通知里显示的机器人名称
FEISHU_WEBHOOK_URL= # 飞书机器人 Webhook 地址（为空则不推送）
FEISHU_SECRET= # 飞书签名密钥（未开启签名校验可留空）
FEISHU_NOTIFY_COOLDOWN_MS=300000 # 同类通知最短间隔（毫秒）
FEISHU_NOTIFY_STARTUP=true # 是否推送启动/重启通知
FEISHU_NOTIFY_TRADE_SUCCESS=true # 是否推送成交成功通知
FEISHU_NOTIFY_TRADE_FAILURE=true # 是否推送最终失败通知
FEISHU_NOTIFY_RUNTIME_ISSUES=true # 是否推送运行异常通知
FEISHU_NOTIFY_GUARD_EVENTS=true # 是否推送风控拦截通知
FEISHU_NOTIFY_DRY_RUN=false # 是否推送 dry-run 模拟通知
FEISHU_NOTIFY_WEEKLY_SUMMARY=true # 是否推送每周汇总卡片
FEISHU_NOTIFY_DAILY_DCA_SUCCESS=false # 是否推送“每日定投”成交成功通知
FEISHU_NOTIFY_DEEP_BUY_SUCCESS=true # 是否推送“深跌加仓”成交成功通知
FEISHU_NOTIFY_DEEP_BUY_COOLDOWN_SKIP=false # 是否推送“深跌加仓冷却中跳过”通知
BASE_RPC_URL=https://mainnet.base.org # Base 链 RPC 节点地址
BASE_WALLET_ADDRESS= # 交易钱包地址（建议与私钥对应）
BASE_PRIVATE_KEY= # 钱包私钥（实盘必填，严禁泄露）
TRADING_TIMEZONE=Asia/Shanghai # 策略时间基准时区
DAILY_DCA_ENABLED=true # 是否启用“每日定投”策略
DAILY_DCA_THRESHOLD_USD=0.005 # 每日定投触发价格上限（USD）
DAILY_DCA_AMOUNT_USDC=2 # 每日定投每次买入金额（USDC）
DAILY_DCA_HOUR=24 # 每日定投触发小时（24 表示次日 00:00）
DAILY_DCA_MINUTE=0 # 每日定投触发分钟
DAILY_DCA_WINDOW_MINUTES=30 # 每日定投有效触发窗口（分钟）
DEEP_BUY_ENABLED=true # 是否启用“深跌加仓”策略
DEEP_BUY_THRESHOLD_USD=0.004 # 深跌加仓触发价格上限（USD）
DEEP_BUY_AMOUNT_USDC=10 # 深跌加仓每次买入金额（USDC）
DEEP_BUY_COOLDOWN_DAYS=5 # 深跌加仓冷却天数
WEEKLY_SUMMARY_ENABLED=true # 是否启用每周汇总逻辑
WEEKLY_SUMMARY_WEEKDAY=1 # 每周汇总星期几发送（1=周一，7=周日）
WEEKLY_SUMMARY_HOUR=7 # 每周汇总发送小时（按 TRADING_TIMEZONE）
WEEKLY_SUMMARY_MINUTE=0 # 每周汇总发送分钟
APPROVE_AMOUNT_USDC= # USDC 预授权额度（留空则按策略需要自动计算）
SLIPPAGE_PERCENT=1 # 滑点容忍百分比
MAX_PRICE_IMPACT_PERCENT=5 # 最大可接受价格影响百分比
MAX_TAX_RATE=0.05 # 最大可接受代币税率（0.05=5%）
POLL_INTERVAL_MS=5000 # 价格轮询间隔（毫秒）
MAX_BUYS_PER_DAY=2 # 每日最多成交次数（所有策略合计）
DAILY_BUY_BUDGET_USDC=12 # 每日最多花费预算（USDC）
MIN_BASE_ETH_BALANCE=0.0001 # 最低 Base ETH 余额（用于 gas）
MAX_AIDOG_BALANCE= # AIDOG 持仓上限（留空表示不限制）
MAX_TRADE_ATTEMPTS=2 # 单次信号最大重试次数
TRADE_RETRY_BASE_MS=1500 # 重试基础等待时间（毫秒）
CONFIRMATIONS_REQUIRED=1 # 交易确认区块数
GAS_LIMIT_MULTIPLIER=1.2 # 估算 gasLimit 放大系数
OKX_MAX_RETRIES=3 # OKX API 最大重试次数
OKX_RETRY_BASE_MS=500 # OKX API 重试基础间隔（毫秒）
LOCK_FILE=data/state/aidog-bot.lock # 单实例锁文件路径
STATE_FILE=data/state/aidog-bot-state.json # 运行状态持久化文件路径
LOG_FILE=data/logs/aidog-bot.log # 运行日志文件路径
TRADE_LOG_FILE=data/logs/aidog-trades.jsonl # 成交日志文件路径（JSONL）
BUY_ONCE=false # 是否首笔成交后立即退出
DRY_RUN=true # 是否模拟模式（true 不发真实交易）
MAX_SAMPLES=0 # 最多采样次数（0 表示不限制）

# 服务器配置

SERVER_IP= # 云服务器公网 IP（用于一键部署脚本）

SERVER_PASSWORD= # 云服务器登录密码（仅本地部署使用）

SERVER_USER=root # 云服务器登录用户名
